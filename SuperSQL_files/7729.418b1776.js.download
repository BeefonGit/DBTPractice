  .react-grid-item {
    transition: none !important;
    contain: layout;
  }

  .react-grid-item.react-grid-placeholder {
    background-color: ${i.lx.reusableSelectedHoveredBackground};
    border-radius: ${c.T["radius-sm"]};
  }

  .react-grid-item > .react-resizable-handle {
    --resize-handle-color: ${i.lx.reusableBorderHover};
    opacity: 0;
    transition: opacity 0.15s ease-in-out;
    background-image: none;
    padding: 0;
  }

  .react-grid-item > .react-resizable-handle::after {
    display: none;
  }

  .react-grid-item:hover > .react-resizable-handle {
    opacity: 1;
  }

  .react-grid-item > .react-resizable-handle:hover {
    --resize-handle-color: ${i.lx.reusableBorderBright};
  }

  .react-grid-item > .react-resizable-handle:active {
    --resize-handle-color: ${i.lx.reusableSelectedUi};
  }

  .react-grid-item.resizing::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid ${i.lx.reusableSelectedUi};
    border-radius: ${c.T["radius-sm"]};
    pointer-events: none;
    z-index: 1;
  }
