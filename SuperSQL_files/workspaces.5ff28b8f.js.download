  // Chart type \u{2014} primary dropdown matching the live-app "Chart type" field
  form.appendChild(chRow(__i18n.chartType, chSel(s.type || 'grouped-bar', [
    ['grouped-bar', __i18n.barChart],
    ['stacked-bar', __i18n.stackedBarChart],
