  td { padding: 6px 12px; border-bottom: 1px solid #e2e8f0; white-space: nowrap; max-width: 300px; overflow: hidden; text-overflow: ellipsis; }
  tr:nth-child(even) { background-color: #f8fafc; }
  .table-note { font-size: 11px; color: #64748b; margin-top: 4px; }
