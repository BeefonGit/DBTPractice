(lambda: (
    exec("""
def __snow_vi_collect():
    import json, inspect, reprlib, time
    start = time.monotonic()
    TIMEOUT = 5.0
    HEAVY = {
        ('pyspark.sql.dataframe', 'DataFrame'),
        ('pyspark.sql.connect.dataframe', 'DataFrame'),
        ('pyspark.sql.session', 'SparkSession'),
        ('pyspark.sql.connect.session', 'SparkSession'),
        ('pyspark.sql.column', 'Column'),
        ('pyspark.sql.connect.column', 'Column'),
        ('pyspark.sql.group', 'GroupedData'),
        ('pyspark.sql.connect.group', 'GroupedData'),
        ('pyspark.sql.readwriter', 'DataFrameReader'),
        ('pyspark.sql.readwriter', 'DataFrameWriter'),
        ('pyspark.pandas.frame', 'DataFrame'),
        ('pyspark.pandas.series', 'Series'),
        ('snowflake.snowpark.session', 'Session'),
        ('snowflake.snowpark.dataframe', 'DataFrame'),
        ('snowflake.snowpark.column', 'Column'),
        ('snowflake.snowpark.relational_grouped_dataframe', 'RelationalGroupedDataFrame'),
        ('django.db.models.query', 'QuerySet'),
        ('ibis.expr.types.relations', 'Table'),
        ('ray.data.dataset', 'Dataset'),
        ('snowflake.ml.data.data_connector', 'DataConnector'),
        ('snowflake.ml.data.sharded_data_connector', 'ShardedDataConnector'),
        ('snowflake.ml.dataset.dataset', 'Dataset'),
        ('modin.pandas.dataframe', 'DataFrame'),
        ('modin.pandas.series', 'Series'),
        ('dask.dataframe.dask_expr._collection', 'DataFrame'),
        ('dask.dataframe.dask_expr._collection', 'Series'),
        ('dask.dataframe.core', 'DataFrame'),
        ('dask.dataframe.core', 'Series'),
        ('duckdb', 'DuckDBPyRelation'),
        # DuckDB >= 0.9 reports __module__ as the internal C-extension path.
        ('duckdb.duckdb', 'DuckDBPyRelation'),
        ('polars.dataframe.frame', 'DataFrame'),
        ('polars.series.series', 'Series'),
        ('plotly.basedatatypes', 'BaseFigure'),
        ('plotly.graph_objs._figure', 'Figure'),
    }
    def is_heavy(v):
        try:
            for cls in type(v).__mro__:
                if (getattr(cls, '__module__', '') or '', cls.__name__) in HEAVY:
                    return True
        except Exception:
            pass
        return False
    r = reprlib.Repr()
    r.maxstring = 500
    r.maxother = 500
    r.maxlong = 500
    r.maxlist = 100
    r.maxarray = 100
    r.maxdict = 100
    r.maxset = 100
    r.maxfrozenset = 100
    r.maxdeque = 100
    r.maxtuple = 100
    r.repr_bytes = lambda x, level: repr(x[:50])[:200]
    r.repr_bytearray = lambda x, level: repr(x[:50])[:200]
    orig_ri = r.repr_instance
    # Custom objects without a reprlib handler fall through to repr_instance,
    # which calls builtins.repr() - materializing the full string before
    # truncating to maxother chars. A custom type with small __sizeof__ but
    # huge __repr__ output could theoretically OOM. This is inherently
    # unpredictable without calling repr. MemoryError (subclass of Exception)
    # is caught by the except block below. The 10MB threshold targets
    # genuinely large objects where builtins.repr() would be most dangerous.
    r.repr_instance = lambda x, level: ('<' + type(x).__name__ + ' (~' + str(x.__sizeof__() // 1_000_000) + 'MB)>') if (hasattr(x, '__sizeof__') and x.__sizeof__() > 10_000_000) else orig_ri(x, level)
    result = []
    # Counters for the three mutually-exclusive preview paths, surfaced
    # in the meta dict so telemetry can track where overhead is coming
    # from in production (heavy = short-circuit stub, smart = ML tensor
    # metadata preview, generic = fell through to reprlib).
    heavy_count = 0
    smart_count = 0
    generic_count = 0
    timed_out = False
    for name, val in list(globals().items()):
        # Time check before the skip filter: a globals() with thousands of
        # IPython _-prefixed entries or user functions could burn seconds
        # iterating the skip predicates before any time check ran.
        if time.monotonic() - start > TIMEOUT:
            timed_out = True
            break
        # Skip our own function so it doesn't appear as a variable.
        if name == '__snow_vi_collect':
            continue
        if name.startswith('_') or callable(val) or inspect.ismodule(val) or name in ('In','Out','get_ipython','exit','quit'):
            continue
        try:
            mod = type(val).__module__
            t = mod + '.' + type(val).__name__ if mod and mod != 'builtins' else type(val).__name__
        except Exception:
            t = 'unknown'
        if is_heavy(val):
            heavy_count += 1
            result.append({'name': name, 'type': t, 'shape': None, 'preview': '<' + t + '>'})
            continue
        # Smart previews for ML framework tensors and nn.Module. The generic
        # repr() path for these types forces device-to-host sync (CUDA/TPU
        # tensors) or recursively walks a many-thousand-module architecture
        # (LLM nn.Module subclasses). Shape/dtype/device are pure metadata
        # and always cheap. Fall through to the generic path on any failure.
        smart = False
        try:
            mro_names = [(getattr(c, '__module__', '') or '', c.__name__) for c in type(val).__mro__]
            # Match on exact package or dotted sub-package only. Plain
            # startswith('torch') would also match torchvision / torchao /
            # torchtext \u{2014} if any of those defines a Tensor/Parameter class
            # we would fire the branch, hit an attribute error on .shape/
            # .dtype/.device, and silently fall through to generic repr()
            # (which is exactly what this smart-preview branch exists to
            # avoid). Same trap for tensorflow, jax, jaxlib, cupy.
            if any((m == 'torch' or m.startswith('torch.')) and cn in ('Tensor', 'Parameter', 'UninitializedParameter') for m, cn in mro_names):
                s = list(val.shape)
                p = '<' + t + ' shape=' + str(tuple(val.shape)) + ' dtype=' + str(val.dtype) + ' device=' + str(val.device) + '>'
                smart = True
            elif any((m == 'tensorflow' or m.startswith('tensorflow.')) and cn in ('EagerTensor', 'Variable', 'ResourceVariable') for m, cn in mro_names):
                # Unknown-rank tensors (tf.keras.Input(shape=None)) raise
                # TypeError on tuple(TensorShape(None)); unusual dtypes (some
                # resource handles) lack .name. Guard both so the branch
                # doesn't throw and silently fall through to generic repr()
                # -- which for EagerTensors triggers device-to-host sync.
                s = list(val.shape) if val.shape.rank is not None else None
                shape_str = str(tuple(val.shape)) if val.shape.rank is not None else '?'
                dtype_str = getattr(val.dtype, 'name', str(val.dtype))
                p = '<' + t + ' shape=' + shape_str + ' dtype=' + dtype_str + '>'
                smart = True
            elif any((m == 'jax' or m == 'jaxlib' or m.startswith('jax.') or m.startswith('jaxlib.')) and cn in ('Array', 'ArrayImpl') for m, cn in mro_names):
                s = list(val.shape)
                p = '<' + t + ' shape=' + str(tuple(val.shape)) + ' dtype=' + str(val.dtype) + '>'
                smart = True
            elif any((m == 'cupy' or m.startswith('cupy.')) and cn == 'ndarray' for m, cn in mro_names):
                # cupy.ndarray.__repr__ calls repr(self.get()) which performs
                # a blocking GPU->host copy of the full array. Shape/dtype
                # are always cheap metadata.
                s = list(val.shape)
                p = '<' + t + ' shape=' + str(tuple(val.shape)) + ' dtype=' + str(val.dtype) + ' device=' + str(val.device) + '>'
                smart = True
            elif any((m == 'torch.nn.modules' or m.startswith('torch.nn.modules.')) and cn == 'Module' for m, cn in mro_names):
                # Parameter count is O(num-parameter-tensors), not O(values).
                # A 70B LLM has ~1k-10k parameter tensors -> a few ms.
                np_count = 0
                for prm in val.parameters():
                    np_count += prm.numel()
                s = None
                p = '<' + t + ' ~' + format(np_count, ',') + ' params>'
                smart = True
        except Exception:
            pass
        if smart:
            smart_count += 1
            result.append({'name': name, 'type': t, 'shape': s, 'preview': p})
            continue
        generic_count += 1
        try:
            s = list(val.shape) if hasattr(val, 'shape') else len(val) if hasattr(val, '__len__') and not isinstance(val, str) else None
        except Exception:
            s = None
        try:
            if isinstance(val, (bytes, bytearray)):
                p = repr(val[:500])[:500]
            elif hasattr(val, '__sizeof__') and val.__sizeof__() > 10_000_000:
                # 10MB shallow size threshold: reprlib's per-type handlers
                # (maxlist, maxdict, etc.) are the primary defense for
                # built-in collections. This catches custom/large objects
