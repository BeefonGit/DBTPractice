    yEnc = { field: '__value__', type: 'quantitative', axis: { title: yTitle } };
    if (agg !== 'none') yEnc.aggregate = agg;
  } else {
    yEnc = yF ? { field: yF, type: vt(yF), axis: { title: yTitle } } : null;
    if (yEnc && agg !== 'none') yEnc.aggregate = agg;
