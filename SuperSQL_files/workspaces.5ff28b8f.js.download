        gap: 8px !important;
      }
      .dcm-section-content label + * { margin-top: 0; }
      .dcm-section-content {
        cursor: default !important;
        user-select: text !important;
      }
      .dcm-section-content * {
        cursor: inherit;
      }
      .dcm-section-content input,
      .dcm-section-content textarea,
      .dcm-section-content [contenteditable="true"] {
        cursor: text !important;
        user-select: text !important;
      }
      .dcm-section-content button,
      .dcm-section-content [role="button"],
      .dcm-section-content [role="combobox"],
      .dcm-section-content [role="listbox"],
      .dcm-section-content a {
        cursor: pointer !important;
      }
      .dcm-section-content label + button[aria-labelledby][aria-expanded] {
        position: relative !important;
        left: 3px !important;
        align-self: center !important;
        width: 18px !important;
        height: 18px !important;
        min-width: 18px !important;
        min-height: 18px !important;
        padding: 0 !important;
      }
      .dcm-section-content label + button[aria-labelledby][aria-expanded] svg {
        width: 12px !important;
        height: 12px !important;
      }
