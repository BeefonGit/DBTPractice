    /* Hidden by default. */
    .connect-handle-dot {
      opacity: 0;
    }
    /* Show when the node is hovered. */
    .react-flow__node:hover .connect-handle-dot {
      opacity: 1;
    }
    /* Show on every connectable handle while a drag is in progress so the
       user can see which targets accept the drop. :has() is needed because
       xyflow only annotates the source handle with .connectingfrom, not a
       canvas-level "is dragging" class. */
    .react-flow:has(.react-flow__handle.connect-handle.connectingfrom)
      .connect-handle-dot {
      opacity: 1;
    }
    /* Source handle while dragging \u{2014} keep the dot visible at its anchor. */
    .connect-handle.connectingfrom + .connect-handle-dot {
      opacity: 1 !important;
      background-color: ${tV.x.reusableIconSubtle} !important;
    }
    /* Valid drop target \u{2014} light green halo. */
    .connect-handle.valid + .connect-handle-dot {
      opacity: 1 !important;
      width: 10px !important;
      height: 10px !important;
      background-color: ${tV.x.statusSuccessUi} !important;
      box-shadow: 0 0 0 3px ${tV.x.statusSuccessBackground} !important;
    }
    /* Invalid drop target \u{2014} subtle red. */
    .connect-handle.connectingto:not(.valid) + .connect-handle-dot {
      opacity: 1 !important;
      width: 8px !important;
      height: 8px !important;
      background-color: ${tV.x.statusCriticalUi} !important;
    }
