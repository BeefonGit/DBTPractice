(function() {
  // Null-prototype objects: a malicious widget that injects a key like
  // '__proto__' into a state delta cannot mutate Object.prototype through
  // these maps. Defense in depth \u{2014} the iframe sandbox already contains the
  // blast radius, but this prevents corruption of the shim's own state.
  var SAVE_PAYLOAD_MAX_BYTES = 1000000;
  var state = Object.create(null);
  var listeners = Object.create(null);
  var pendingChanges = Object.create(null);

  // Mount gate: updates received before render() completes are applied to
  // state (so model.get() returns current values) but change: events are
  // queued and replayed after mount. This prevents Plotly (and similar
  // widgets) from calling addTraces/restyle on a chart that doesn't exist
  // yet \u{2014} their render() registers model.on('change:...') listeners that
  // assume the DOM element is already populated by Plotly.newPlot().
  var mounted = false;
  var queuedChangeEvents = [];

  // Init replay: the ESM bootstrap script (<script type="module">) is
  // implicitly DEFERRED \u{2014} it runs after this synchronous shim finishes AND
  // after the document is parsed. The parent's anywidget:init can arrive
  // BEFORE the bootstrap runs, in which case the bootstrap's own
  // 'message' listener would never fire (it isn't registered yet) and
  // Plotly never mounts \u{2192} blank cell.
  //
  // This hook lets the bootstrap subscribe to init via a function call
  // instead of a message listener. If init has already arrived by the time
  // the bootstrap calls it, we invoke the callback synchronously; otherwise
  // we queue it to fire when init arrives. Either way, no race.
  var initAlreadyReceived = false;
  var initListeners = [];

  function copyToNullProto(src) {
    var dst = Object.create(null);
    if (!src) return dst;
    var keys = Object.keys(src);
    for (var i = 0; i < keys.length; i++) { dst[keys[i]] = src[keys[i]]; }
    return dst;
  }

  var model = {
    get: function(key) {
      return state[key];
    },
    set: function(key, value) {
      state[key] = value;
      pendingChanges[key] = value;
      fire('change:' + key, value);
    },
    save_changes: function() {
      if (Object.keys(pendingChanges).length === 0) return;
      var serialized;
      try {
        serialized = JSON.parse(JSON.stringify(pendingChanges));
      } catch(e) {
        console.error('[anywidget] save_changes: state is not JSON-serializable', e);
        // Clear pendingChanges on error \u{2014} otherwise every subsequent
        // save_changes() call fails on the same poisoned state.
        pendingChanges = Object.create(null);
        return;
      }
      // Cap iframe-side payload before postMessage. A widget that does
      // model.set('giant', new Array(1e7).fill('x')) and save_changes()
      // would otherwise burn main-thread time on multiple structured-clones
      // through every layer (postMessage \u{2192} kernel comm send).
      var raw = JSON.stringify(serialized);
      if (raw.length > SAVE_PAYLOAD_MAX_BYTES) {
        console.error('[anywidget] save_changes: payload exceeds size cap; dropped');
        pendingChanges = Object.create(null);
        return;
      }
      window.parent.postMessage({
        type: 'anywidget:save',
        state: serialized
      }, '*');
      pendingChanges = Object.create(null);
    },
    on: function(event, callback) {
      if (!listeners[event]) listeners[event] = [];
      listeners[event].push(callback);
    },
    off: function(event, callback) {
      // Backbone semantics: off() clears all listeners; off(event) clears all
      // for that event; off(event, cb) removes only that callback. The shim
      // previously no-op'd both off() and off(event) variants.
      if (!event) { listeners = Object.create(null); return; }
      if (!listeners[event]) return;
      if (!callback) { listeners[event] = []; return; }
      listeners[event] = listeners[event].filter(function(cb) { return cb !== callback; });
    },
    send: function(data) {
      window.parent.postMessage({
        type: 'anywidget:custom',
        data: data
      }, '*');
    },
    widget_manager: {
      // Stub: only the current model is available inside the iframe. If a
      // widget passes a different model_id (cross-widget lookup, e.g. shared
      // colorscale or a parent/child relationship), this returns the wrong
      // model silently. Plotly does not exercise this today; revisit if a
      // widget reports unexpected behavior here.
      get_model: function(_model_id) { return Promise.resolve(model); }
