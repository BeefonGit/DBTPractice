  /* Tables \u{2014} give them visible borders and a header background so
   * tabular data is readable in any browser. The editor's column
   * resize handles only show inside edit mode; the saved file just
   * shows the bordered grid. */
  table {
    border-collapse: collapse;
    margin: 16px 0;
    width: 100%;
  }
  th, td {
    border: 1px solid #d1d5db;
    padding: 6px 10px;
    vertical-align: top;
    text-align: left;
  }
  th {
    background: #f3f4f6;
    font-weight: 600;
  }

  /* Callouts \u{2014} semantic <aside class="callout callout-{variant}"> with
   * a coloured left border and a soft tinted background. Variant
   * colours mirror the editor's edit-mode appearance. */
  aside.callout {
    margin: 16px 0;
    padding: 12px 16px;
    border-inline-start: 4px solid #d1d5db;
    border-radius: 0 6px 6px 0;
    background: #f9fafb;
  }
  aside.callout > p:first-child { margin-top: 0; }
  aside.callout > p:last-child { margin-bottom: 0; }
  aside.callout-info {
    border-inline-start-color: #2563eb;
    background: #eff6ff;
  }
  aside.callout-warning {
    border-inline-start-color: #d97706;
    background: #fffbeb;
  }
  aside.callout-tip {
    border-inline-start-color: #16a34a;
    background: #f0fdf4;
  }

  /* Task lists \u{2014} supports two markup shapes:
   *   1. Editor-authored: li > label[input] + div[p]. TipTap's TaskItem
   *      nodeView injects the label and div wrappers at runtime.
   *   2. Hand-authored / saved file: li[data-checked] > p, with an
   *      optional nested ul[data-type=taskList] as a sibling.
   * Both shapes need to render identically. flex-wrap keeps a nested
   * task list from being squeezed onto the same row as the parent
   * task's text. The data-checked attribute is rendered as a styled
   * checkbox via ::before in the hand-authored shape; the editor
   * shape uses a real input element instead. */
  ul[data-type="taskList"] {
    list-style: none;
    padding-left: 4px;
  }
  ul[data-type="taskList"] li {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 8px;
    margin: 4px 0;
  }
  ul[data-type="taskList"] li > label {
    flex: 0 0 auto;
    /* Vertical alignment of checkbox to first text line \u{2014} see header
     * comment in editorRuntimeStyles.ts for sizing rationale. */
    margin-top: 0.35em;
  }
  ul[data-type="taskList"] li > div {
    flex: 1 1 auto;
    min-width: 0;
  }
  /* Zero p margins inside both shapes so text aligns with the checkbox.
   * Without this, the document's own paragraph margins push text down a
   * line below the checkbox. Targets the editor-nodeView paragraph (a
   * direct child of the content slot div) AND the hand-authored
   * paragraph (a direct child of the li). */
  ul[data-type="taskList"] li > div > p,
  ul[data-type="taskList"] li > p {
    margin: 0;
    /* Make the paragraph fill the remaining row so the synthesised
     * ::before checkbox doesn't get pushed onto its own line and any
     * nested <ul> wraps onto a new row instead of squeezing alongside. */
    flex: 1 1 auto;
    min-width: 0;
  }
  /* Nested task lists must drop to a new row and indent under the
   * parent task's text rather than sit beside the checkbox. */
  ul[data-type="taskList"] li > ul[data-type="taskList"] {
    flex: 1 0 100%;
    margin-inline-start: 28px;
    margin-block: 4px 0;
  }
  /* Synthesised checkbox via ::before for the hand-authored shape.
   * Editor shape has a real <label><input> and skips this rule. */
  ul[data-type="taskList"] li:not(:has(> label))::before {
    content: "";
    flex: 0 0 auto;
    width: 14px;
    height: 14px;
    margin-top: 0.35em;
    border: 1.5px solid #6b7280;
    border-radius: 3px;
    background: #ffffff;
  }
  ul[data-type="taskList"] li[data-checked="true"]:not(:has(> label))::before {
    background: #2563eb;
    border-color: #2563eb;
    /* SVG check mark in white */
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 14 14'><path fill='none' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' d='M3 7.5l3 3 5-6'/></svg>");
    background-repeat: no-repeat;
    background-position: center;
  }
  /* Strikethrough on completed items \u{2014} both shapes. */
  ul[data-type="taskList"] li[data-checked="true"] > div > p,
  ul[data-type="taskList"] li[data-checked="true"] > p {
    color: #6b7280;
    text-decoration: line-through;
  }

  /* Details \u{2014} give the disclosure a subtle frame matching the editor.
   * Browsers handle the click-to-expand natively, we only style the
   * surrounding box. */
  details {
    margin: 12px 0;
    padding: 8px 12px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: #ffffff;
  }
  details > summary {
    font-weight: 600;
    cursor: pointer;
    padding: 4px 0;
  }

  /* Figure \u{2014} center captioned media with a small italic caption.
   * Mirrors the editor's appearance so user-resized figure images
   * stay visually consistent. */
  figure {
    margin: 16px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  figure > figcaption {
    margin-top: 6px;
    font-size: 13px;
    color: #6b7280;
    text-align: center;
    font-style: italic;
  }

  /* Blockquote \u{2014} match the editor's left-border treatment so quoted
   * passages remain visually distinct outside the editor. */
  blockquote {
    border-inline-start: 3px solid #d1d5db;
    margin: 12px 0;
    padding: 4px 16px;
    color: #6b7280;
  }

  /* Code blocks \u{2014} light backdrop so they read as a code panel. */
  pre {
    background: #f3f4f6;
    padding: 12px 16px;
    border-radius: 6px;
    overflow-x: auto;
  }
  code {
    background: #f3f4f6;
    padding: 1px 6px;
    border-radius: 3px;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.9em;
  }
  pre > code {
    background: transparent;
    padding: 0;
  }
