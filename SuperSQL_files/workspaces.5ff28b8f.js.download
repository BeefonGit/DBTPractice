ription:'Do not translate "default" as it is a specific Jinja filter name.'})},{label:"dictsort",info:(0,n.WI)({id:"Sort a dict and yield (key, value) pairs. Example: '{{' '{''b': 1, 'a': 2'}' | dictsort '}}'",description:'Do not translate "dictsort" as it is a specific Jinja filter name.'})},{label:"escape",info:(0,n.WI)({id:"Escape HTML characters. Example: '{{' '<p>' | escape '}}' outputs '<p>'",description:'Do not translate "escape" as it is a specific Jinja filter name.'})},{label:"filesizeformat",info:(0,n.WI)({id:"Format a number as a human-readable file size. Example: '{{' 1024 | filesizeformat '}}' outputs '1.0 KB'",description:'Do not translate "filesizeformat" as it is a specific Jinja filter name.'})},{label:"first",info:(0,n.WI)({id:"Return the first item of a sequence. Example: '{{' [1, 2, 3] | first '}}' outputs 1",description:'Do not translate "first" as it is a specific Jinja filter name.'})},{label:"float",info:(0,n.WI)({id:"Convert the value into a floating point number. Example: '{{' '3.14' | float '}}' outputs 3.14",description:'Do not translate "float" as it is a specific Jinja filter name.'})},{label:"forceescape",info:(0,n.WI)({id:"Enforce HTML escaping even if autoescape is off. Example: '{{' '<p>' | forceescape '}}'",description:'Do not translate "forceescape" as it is a specific Jinja filter name.'})},{label:"format",info:(0,n.WI)({id:"Apply Python string formatting. Example: '{{' '%s, %s!' | format('Hello', 'world') '}}' outputs 'Hello, world!'",description:'Do not translate "format" as it is a specific Jinja filter name.'})},{label:"groupby",info:(0,n.WI)({id:"Group a sequence of objects by an attribute. Example: '{{' items | groupby('type') '}}'",description:'Do not translate "groupby" as it is a specific Jinja filter name.'})},{label:"indent",info:(0,n.WI)({id:"Indent a string with spaces. Example: '{{' 'hi' | indent(4) '}}' outputs '    hi'",description:'Do not translate "indent" as it is a specific Jinja filter name.'})},{label:"int"