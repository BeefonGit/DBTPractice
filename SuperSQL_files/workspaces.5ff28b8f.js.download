:(0,n.WI)({id:"Return a random item from the sequence. Example: '{{' [1, 2, 3] | random '}}'",description:'Do not translate "random" as it is a specific Jinja filter name.'})},{label:"reject",info:(0,n.WI)({id:"Reject items from a sequence where a test fails. Example: '{{' [1, 2, 3] | reject('even') '}}' outputs [1, 3]",description:'Do not translate "reject" as it is a specific Jinja filter name.'})},{label:"rejectattr",info:(0,n.WI)({id:"Reject items from a sequence based on an attribute test. Example: '{{' objs | rejectattr('id', 'even') '}}'",description:'Do not translate "rejectattr" as it is a specific Jinja filter name.'})},{label:"replace",info:(0,n.WI)({id:"Replace parts of a string. Example: '{{' 'Hello' | replace('H', 'J') '}}' outputs 'Jello'",description:'Do not translate "replace" as it is a specific Jinja filter name.'})},{label:"reverse",info:(0,n.WI)({id:"Reverse a sequence. Example: '{{' [1, 2, 3] | reverse '}}' outputs [3, 2, 1]",description:'Do not translate "reverse" as it is a specific Jinja filter name.'})},{label:"round",info:(0,n.WI)({id:"Round a number. Example: '{{' 3.7 | round '}}' outputs 4",description:'Do not translate "round" as it is a specific Jinja filter name.'})},{label:"safe",info:(0,n.WI)({id:"Mark a string as safe to prevent escaping. Example: '{{' '<p>' | safe '}}' outputs '<p>'",description:'Do not translate "safe" as it is a specific Jinja filter name.'})},{label:"select",info:(0,n.WI)({id:"Select items from a sequence where a test passes. Example: '{{' [1, 2, 3] | select('even') '}}' outputs [2]",description:'Do not translate "select" as it is a specific Jinja filter name.'})},{label:"selectattr",info:(0,n.WI)({id:"Select items from a sequence based on an attribute test. Example: '{{' objs | selectattr('id', 'even') '}}'",description:'Do not translate "selectattr" as it is a specific Jinja filter name.'})},{label:"slice",info:(0,n.WI)({id:"Slice a sequence into chunks. Example: '{{' [1, 2, 3, 4] | slice(2) '}}' outputs [[1,