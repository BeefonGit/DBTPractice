.report-page {
  max-width: 880px;
  margin: 0 auto;
  padding: 48px 32px 80px;
  font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif;
  color: #2b3145;
  line-height: 1.6;
  font-size: 15px;
}
.report-prose h1,
.report-prose h2,
.report-prose h3,
.report-prose h4,
.report-prose h5,
.report-prose h6 {
  margin: 28px 0 12px;
  color: #1a1f33;
  font-weight: 600;
  line-height: 1.25;
}
.report-prose h1 { font-size: 28px; }
.report-prose h2 { font-size: 22px; }
.report-prose h3 { font-size: 18px; }
.report-prose h4 { font-size: 16px; }
.report-prose p { margin: 12px 0; }
.report-prose ul,
.report-prose ol { padding-left: 24px; margin: 12px 0; }
.report-prose li { margin: 4px 0; }
.report-prose blockquote {
  border-left: 3px solid #d6dbe8;
  margin: 16px 0;
  padding: 4px 16px;
  color: #4a5170;
}
.report-prose code {
  background: #f1f3f9;
  padding: 1px 6px;
  border-radius: 3px;
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 13px;
}
.report-prose pre {
  background: #f1f3f9;
  padding: 12px 16px;
  border-radius: 6px;
  overflow-x: auto;
  font-size: 13px;
}
.report-prose img { max-width: 100%; height: auto; }
.report-atomic-block {
  margin: 24px 0;
  border: 1px solid #e3e6f0;
  border-radius: 8px;
  background: #ffffff;
  overflow: hidden;
}
.report-atomic-block > .output-image,
.report-atomic-block > .output-html {
  padding: 12px 16px;
}
.report-atomic-block > .output-image img { max-width: 100%; height: auto; }
.report-atomic-block .dg-container { border: none; }
@media print {
  .report-atomic-block { break-inside: avoid; page-break-inside: avoid; }
}
