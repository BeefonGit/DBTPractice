(function() {
  var lastHeight = 0;
  function measure() {
    var bodyH = document.body.scrollHeight;
    var docEl = document.documentElement;
    // Only contribute docEl.scrollHeight when it indicates real overflow
    // beyond the viewport. Otherwise scrollHeight == clientHeight == current
    // iframe height, which would prevent shrinking small widgets.
    var htmlH = docEl.scrollHeight > docEl.clientHeight ? docEl.scrollHeight : 0;
    // Walk body's direct children: O(small N) and catches absolutely-positioned
    // chart wrappers whose layout area scrollHeight would otherwise miss.
    // body has margin:0 so getBoundingClientRect bottom == distance from body top.
    var maxChildBottom = 0;
    var children = document.body.children;
    for (var i = 0; i < children.length; i++) {
      var rect = children[i].getBoundingClientRect();
      if (rect.bottom > maxChildBottom) maxChildBottom = rect.bottom;
    }
    return Math.max(bodyH, htmlH, Math.ceil(maxChildBottom));
  }
  function sendHeight() {
    var height = measure();
    // height can be 0 during a brief boot flicker (body not yet laid out).
    // The parent's parseIframeHeight() rejects h <= 0, so posting 0 is
    // harmless but we skip it here to keep the contract explicit.
    if (height > 0 && height !== lastHeight) {
      lastHeight = height;
      window.parent.postMessage({ type: 'iframeHeight', height: height }, '*');
    }
  }
  var resizeObserver = new ResizeObserver(sendHeight);
  resizeObserver.observe(document.body);
  resizeObserver.observe(document.documentElement);
  var mutationObserver = new MutationObserver(sendHeight);
  mutationObserver.observe(document.body, {
    childList: true,
    subtree: true,
    attributes: true,
    attributeFilter: ['style', 'width', 'height', 'class']
  });
  sendHeight();
})();
