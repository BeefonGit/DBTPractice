                scanner_id,
                state,
                severity,
                updated_on,
                (UPPER(state) in ('OPEN', 'RESOLVED MANUALLY', 'MUTED')) as included,
            FROM snowflake.organization_usage.trust_center_findings
            WHERE account_name != ?
            UNION ALL
            SELECT
                event_id as id,
                ? as account_name,
                scanner_package_id,
                scanner_id,
                state,
                severity,
                end_timestamp as updated_on,
                total_at_risk_count > 0 as included,
            FROM snowflake.trust_center.findings
            WHERE scanner_type = 'Vulnerability'
        ),
        latest_account_findings AS (
          SELECT
            scanner_package_id,
            scanner_id,
            suggested_action,
            impact,
            ROW_NUMBER() OVER (
              PARTITION BY scanner_package_id, scanner_id
              ORDER BY start_timestamp DESC NULLS LAST, created_on DESC
            ) as rn
          FROM snowflake.trust_center.findings
          WHERE completion_status = 'SUCCEEDED'
        ),
        latest_org_findings AS (
          SELECT
            id,
            scanner_package_id,
