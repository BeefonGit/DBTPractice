CREATE { OR REPLACE } SEMANTIC VIEW [ IF NOT EXISTS ] <view_name>
TABLES (
  [ <alias_1> AS ] <table_1> [ <primary_key> ] [ <synonyms_comment> ],
  [
  	[ <alias_2> AS ] <table_2> [ <primary_key> ] [ <synonyms_comment> ],
    ...
  ]
)
[ RELATIONSHIPS ( <relationship> [ , <relationship> ,  ... ] ) ]
[ FACTS ( <calculation> [ , <calculation>, ... ] ) ]
[ DIMENSIONS ( <calculation> [ , <calculation>, ... ] ) ]
[ METRICS ( <calculation> [ , <calculation>, ... ] ) ]
[ COMMENT = '<string_literal>' ]
;

--- Where
<primary_key> := PRIMARY KEY ( <col_name> [ , <col_name> , ... ] )

<relationship> := [ <identifier> AS ] <alias_1> ( <col_name> [ , <col_name> , ... ] ) REFERENCES <alias_2> [ ( <ref_col_name> [ , <ref_col_name> , ... ] ) ] ]?

<calculation> :=  ( <alias>.<calculation_name> ) AS <sql_expr> [ <synonyms_comment> ]

<synonyms_comment> :=
