Follow these steps:
Step 1 — Ask me about myself:
- What's my role? (e.g., analyst, data engineer, ML engineer, app developer)
- Which part of the business do I work with most? (e.g., Finance, Marketing, Product, Sales, Operations)
- What does my day-to-day look like? (dashboards, pipelines, models, ad-hoc analysis, etc.)
- What tools am I comfortable with? (SQL, Python, dbt, Streamlit, etc.)
- Any specific project or goal I'm starting with?

Step 2 — Discover my Snowflake environment: Query Snowflake to find my current role, privileges, accessible databases/schemas, and relevant objects based on my answers.

Step 3 — Give me a personalized getting-started plan:
- What I have access to (roles, warehouses, key data)
- Objects to explore first, based on my business area
- Snowflake features relevant to my work
- Quick wins and first tasks I can try right now
- How Cortex Code can help me move faster

Keep it friendly, practical, and matched to my experience level.`,"connect-catalog":"Connect to an external catalog","cost-intelligence":"@(serverSkill:cost-intelligence)","machine-learning":"@(serverSkill:machine-learning)","data-governance":"@(serverSkill:data-governance)","workload-performance-analysis":"@(serverSkill:workload-performance-analysis)","data-quality":"@(serverSkill:data-quality)",lineage:"@(serverSkill:lineage)",integrations:"@(serverSkill:integrations)",semantic_studio:"@(serverSkill:semantic_studio)","cortex-ai-functions":"@(serverSkill:cortex-ai-functions)","trust-center":"@(serverSkill:trust-center)","data-cleanrooms":"@(serverSkill:data-cleanrooms)","notebooks-in-workspaces":"@(serverSkill:notebooks-in-workspaces)","sql-author":"@(serverSkill:sql-author)",dashboard:"@(serverSkill:dashboard)","dbt-projects-on-snowflake":"@(serverSkill:dbt-projects-on-snowflake)","cost-intelligence--weekly-cost":"@(serverSkill:cost-intelligence) What is my Snowflake cost for the past week?","machine-learning--build-deploy":"@(serverSkill:machine-learning) Help me build and deploy a machine learning model on my data","machine-learning--fraud-prediction":"@(serverSkill:machine-learning) Help me engineer a few features and train a model to predict fraud using synthetic data. Use personal databases since we don't intend to persist any artifacts or log the model","data-governance--posture-review":"@(serverSkill:data-governance) Review my data governance posture and help me protect sensitive data","workload-performance-analysis--slow-queries":"@(serverSkill:workload-performance-analysis) Analyze my slowest queries and identify performance bottlenecks","data-quality--schema-health":"@(serverSkill:data-quality) Check the data quality health of my most important schemas","lineage--impact-analysis":"@(serverSkill:lineage) Show me what depends on my table and what breaks if I change it","integrations--create-manage":"@(serverSkill:integrations) Help me create or manage a Snowflake integration","semantic_studio--agent-or-view":"@(serverSkill:semantic_studio) Help me create or manage a Cortex Agent or Semantic View","cortex-ai-functions--text-analysis":"@(serverSkill:cortex-ai-functions) Which Cortex AI function should I use for my text analysis task?","trust-center--findings-remediation":"@(serverSkill:trust-center) Show me my Trust Center security findings and how to fix them","data-cleanrooms--collaborations":"@(serverSkill:data-cleanrooms) Show me my data clean room collaborations and available templates","notebooks-in-workspaces--create-notebook":"@(serverSkill:notebooks-in-workspaces) Create a new Snowflake notebook for data analysis","sql-author--write-optimize":"@(serverSkill:sql-author) Help me write and optimize a SQL query","dashboard--executive-kpi":"@(serverSkill:dashboard) Create an executive KPI dashboard from my data","dbt-projects-on-snowflake--deploy-native":"@(serverSkill:dbt-projects-on-snowflake) Deploy my dbt project to Snowflake as a native object"},gt="prompt-id",gr=e=>{var t;return null!=(t=ge[e])?t:null};var ga=r(712617);let gn={kZKoxP:"blt-1dr59a3",kVQacm:"blt-b3r6kr",kzqmXN:"blt-h8yej3",$$css:!0},gs={kZKoxP:"blt-5yr21d",kzqmXN:"blt-h8yej3",kVQacm:"blt-b3r6kr",$$css:!0},gi=()=>{document.querySelectorAll("iframe").forEach(e=>{e.style.pointerEvents="none"})},go=()=>{document.querySelectorAll("iframe").forEach(e=>{e.style.pointerEvents="auto"});try{requestAnimationFrame(()=>window.dispatchEvent(new CustomEvent("pep-right-panel-resize-end")))}catch(e){}};function gl(){let e=document.getElementById("right-panel");if(!e){try{requestAnimationFrame(()=>window.dispatchEvent(new CustomEvent("pep-right-panel-resize-end")))}catch(e){}return}let t=!1,r=a=>{t=!0,e.removeEventListener("transitionend",r);try{window.dispatchEvent(new CustomEvent("pep-right-panel-resize-end"))}catch(e){}};e.addEventListener("transitionend",r,{once:!0}),window.setTimeout(()=>{if(!t){e.removeEventListener("transitionend",r);try{window.dispatchEve