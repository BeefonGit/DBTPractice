                  IS_APPLICATION_ROLE_IN_SESSION('ORGANIZATION_SECURITY_VIEWER') AS is_organization_security_viewer,
                  IS_APPLICATION_ROLE_IN_SESSION('ORG_USAGE_ADMIN') AS is_org_usage_admin`,bindingsJSON:[]},role:e,isInternal:!0,database:"SNOWFLAKE",desc:"trust-center-org-roles",...t&&{warehouse:t},feature:h6}))({role:e,warehouse:t}))}}async trustCenterAccountsOverview({role:e,warehouse:t,currentAccountName:r}){return{result:await this.sqlQueryBackend.query((({role:e,warehouse:t,currentAccountName:r})=>({sqlQuery:{sqlText:`
          WITH combined_findings AS (
            SELECT
                account_name,
                f.scanner_package_id,
                f.scanner_id,
                f.state,
                severity,
                updated_on,
                (UPPER(f.state) in ('OPEN', 'RESOLVED MANUALLY', 'MUTED')) as included
            FROM snowflake.organization_usage.trust_center_findings f
            LEFT JOIN snowflake.trust_center.scanners s
              ON f.scanner_package_id = s.scanner_package_id
              AND f.scanner_id = s.id
            WHERE true
              AND account_name != ?
              AND s.description IS NOT NULL
              AND s.short_description IS NOT NULL
            UNION ALL
            SELECT
                ? as account_name,
                scanner_package_id,
                scanner_id,
                state,
                severity,
                end_timestamp as updated_on,
                total_at_risk_count > 0 as included
            FROM snowflake.trust_center.findings
            WHERE scanner_type = 'Vulnerability'
          ),
          latest_findings_per_scanner AS (
              SELECT
                  account_name,
                  scanner_package_id,
                  scanner_id,
                  state,
                  severity,
                  updated_on,
                  included,
                  ROW_NUMBER() OVER (
                      PARTITION BY account_name, scanner_package_id, scanner_id
                      ORDER BY updated_on DESC
                  ) AS rn
              FROM combined_findings
              WHERE account_name IS NOT NULL
          ),
          open_vul_count_by_account AS (
            SELECT
              account_name,
              severity,
              count(1) AS finding_count
            FROM latest_findings_per_scanner
            WHERE rn = 1 AND UPPER(state) = 'OPEN' AND included = true
            GROUP BY account_name, severity
          ),
          resolved_vul_count_by_account AS (
            SELECT
              account_name,
              count(1) AS resolved_finding_count
            FROM latest_findings_per_scanner
            WHERE rn = 1 AND (UPPER(state) in ('RESOLVED', 'RESOLVED MANUALLY', 'MUTED')) AND included = true
            GROUP BY account_name
          ),
          aggregated_risks AS (
            SELECT
              account_name,
              SUM(CASE WHEN severity IN ('CRITICAL') THEN finding_count ELSE 0 END) AS critical_sum,
              SUM(CASE WHEN severity IN ('HIGH') THEN finding_count ELSE 0 END) AS high_sum,
              SUM(CASE WHEN severity IN ('MEDIUM') THEN finding_count ELSE 0 END) AS medium_sum,
              SUM(CASE WHEN severity IN ('LOW') THEN finding_count ELSE 0 END) AS low_sum
            FROM open_vul_count_by_account
            GROUP BY account_name
          ),
          scanner_count AS (
            SELECT
              account_name,
              COUNT(DISTINCT scanner_id) AS scanner_count
            FROM combined_findings
            WHERE included = true
            GROUP BY account_name
          )
          SELECT
            ar.account_name,
            ar.critical_sum,
            ar.high_sum,
            ar.medium_sum,
            ar.low_sum,
            rv.resolved_finding_count,
            sc.scanner_count
          FROM aggregated_risks ar
          LEFT JOIN scanner_count sc
            ON sc.account_name = ar.account_name
          LEFT JOIN resolved_vul_count_by_account rv
            ON rv.account_name = ar.account_name
          ORDER BY (ar.critical_sum + ar.high_sum + ar.medium_sum + ar.low_sum) DESC
        `,bindingsJSON:[r,r]},role:e,isInternal:!0,desc:"trust-center-accounts-overview",...t&&{warehouse:t},feature:h6}))({role:e,warehouse:t,currentAccountName:r}))}}async trustCenterOrgViolationTimeSeriesDaily({role:e,warehouse:t,currentAccountName:r,lowerBoundDate:a}){return{result:await this.sqlQueryBackend.query((({role:e,warehouse:t,currentAccountName:r,lowerBoundDate:a})=>({sqlQuery:{sqlText:`
        WITH account_aggregate_by_date AS (
          SELECT
            day_partition,
            ? as account_name,
            SUM(critical_risk_count) as total_critical_findings,
            SUM(high_risk_count) as total_high_findings,
            SUM(medium_risk_count) as total_medium_findings,
            SUM(low_risk_count) as total_low_findings,
            (total_critical_findings + total_high_findings + total_medium_findings + total_low_findings) as total_open_findings
          FROM snowflake.trust_center.time_series_daily_findings
          WHERE day_partition >= TO_DATE(?, 'AUTO')
            AND scanner_type ilike ('VULNERABILITY')
          GROUP BY day_partition, account_name
        ),

        runs AS (
          -- Load all Trust Center findings and create day-level partitions for joining
          SELECT f.*, DATE_TRUNC('DAY', f.updated_on) AS day_partition
          FROM snowflake.organization_usage.trust_center_findings f
          LEFT JOIN snowflake.trust_center.scanners s
            ON f.scanner_package_id = s.scanner_package_id
            AND f.scanner_id = s.id
          WHERE true
            AND f.account_name IS NOT NULL
            AND f.account_name != ?
            AND s.description IS NOT NULL
            AND s.short_description IS NOT NULL
        ),

        date_ranges AS (
          WITH min_max AS (
            SELECT
              MIN(day_partition) as min_date,
              MAX(day_partition) as max_date
            FROM (
              SELECT day_partition FROM account_aggregate_by_date
              UNION ALL
              SELECT day_partition FROM runs
            )
          ),
          date_params AS (
            SELECT
              min_date,
              max_date,
              DATEDIFF(day, min_date, max_date) + 1 as row_count
            FROM min_max
          )
          SELECT DATEADD(day, SEQ4(), dp.min_date) as day_partition
          FROM date_params dp
          CROSS JOIN TABLE(GENERATOR(ROWCOUNT => 365))
          WHERE SEQ4() < dp.row_count
        ),

        -- Create complete grid ensuring every date \xd7 scanner \xd7 account combination exists
        -- This prevents missing data points in the time series (no gaps)
        crossed_dates AS (
          SELECT
            dr.day_partition,
            r.scanner_package_id,
            r.scanner_id,
            r.account_name
          FROM date_ranges dr
          CROSS JOIN (
            -- Get all unique scanner/account combinations that exist in the data
            SELECT DISTINCT scanner_package_id, scanner_id, account_name
            FROM runs
          ) r
        ),

        -- For each date/scanner/account combination, find the most recent finding state
        -- This handles findings that change state over time (Open → Resolved → Closed)
        ranked_runs AS (
          SELECT
            cd.day_partition,
            cd.scanner_package_id,
            cd.scanner_id,
            cd.account_name,
            r.state,
            r.severity,
            -- Rank findings by most recent update for each combination
            ROW_NUMBER() OVER (
              PARTITION BY cd.account_name, cd.scanner_id, cd.scanner_package_id, cd.day_partition
              ORDER BY r.updated_on DESC
            ) as rn
          FROM crossed_dates cd
          LEFT JOIN runs r
            ON cd.scanner_package_id = r.scanner_package_id
            AND cd.scanner_id = r.scanner_id
            AND cd.account_name = r.account_name
            -- Key logic: Include findings that were updated on or before this date
            -- This gives us "point in time" state for each date
            AND cd.day_partition >= r.day_partition
          where cd.day_partition >= TO_DATE(?, 'AUTO')
        ),

        -- Count findings by state and severity for each scanner/account combination
        org_daily_count AS (
          SELECT
            day_partition,
            scanner_package_id,
            scanner_id,
            account_name,
            -- Count only open findings (ignoring resolved/closed)
            COUNT(CASE WHEN UPPER(state) = 'OPEN' THEN 1 END) as open_findings,
            -- Break down open findings by severity level
            COUNT(CASE WHEN UPPER(state) = 'OPEN' AND severity = 'CRITICAL' THEN 1 END) as critical_findings,
            COUNT(CASE WHEN UPPER(state) = 'OPEN' AND severity = 'HIGH' THEN 1 END) as high_findings,
            COUNT(CASE WHEN UPPER(state) = 'OPEN' AND severity = 'MEDIUM' THEN 1 END) as medium_findings,
            COUNT(CASE WHEN UPPER(state) = 'OPEN' AND severity = 'LOW' THEN 1 END) as low_findings
          FROM ranked_runs
          WHERE rn = 1  -- Only count the latest state of each finding for each date
          GROUP BY day_partition, scanner_package_id, scanner_id, account_name
        ),

        -- Aggregate all accounts to get total counts per date
        -- This provides the final time series showing overall vulnerability trends
        org_aggregate_by_date AS (
          SELECT
            day_partition,
            account_name,
            SUM(open_findings) as total_open_findings,
            SUM(critical_findings) as total_critical_findings,
            SUM(high_findings) as total_high_findings,
            SUM(medium_findings) as total_medium_findings,
            SUM(low_findings) as total_low_findings
          FROM org_daily_count
          GROUP BY day_partition, account_name
        )

        -- Final output: time series of vulnerability counts by severity
        SELECT
          day_partition,
          account_name,
          total_open_findings,
          total_critical_findings,
          total_high_findings,
          total_medium_findings,
          total_low_findings
        FROM org_aggregate_by_date
        UNION ALL
        SELECT
          day_partition,
          account_name,
          total_open_findings,
          total_critical_findings,
          total_high_findings,
          total_medium_findings,
          total_low_findings
        FROM account_aggregate_by_date
        ORDER BY day_partition DESC
      `,bindingsJSON:[r,a,r,a]},role:e,isInternal:!0,desc:"trust-center-org-violation-time-series-daily",...t&&{warehouse:t},feature:h6}))({role:e,warehouse:t,currentAccountName:r,lowerBoundDate:a}))}}async trustCenterSetAccountNotificationEnabled(e){return await this.sqlQueryBackend.query((({role:e,warehouse:t,notificationType:r,isEnabled:a})=>({sqlQuery:{sqlText:"call snowflake.trust_center.set_account_notification_enabled(?, ?);",bindingsJSON:[r,a]},role:e,isInternal:!0,desc:"trust-center-set-account-notification-enabled",...t&&{warehouse:t},feature:h6}))(e))}async trustCenterAccountNotificationRecipients(e){return await this.sqlQueryBackend.query((({role:e,warehouse:t})=>({sqlQuery:{sqlText:"select * from snowflake.trust_center.account_notification_recipients;",bindingsJSON:[]},role:e,isInternal:!0,desc:"trust-center-account-notification-recipients",...t&&{warehouse:t},feature:h6}))(e))}async trustCenterOrgTopViolations({role:e,warehouse:t,currentAccountName:r}){return{result:await this.sqlQueryBackend.query((({role:e,warehouse:t,currentAccountName:r})=>({sqlQuery:{sqlText:`
        WITH combined_findings AS (
         SELECT
                account_name,
                f.scanner_package_id,
                f.scanner_id,
                f.state,
                severity,
                updated_on,
                (UPPER(f.state) in ('OPEN', 'RESOLVED MANUALLY', 'MUTED')) as included,
            FROM snowflake.organization_usage.trust_center_findings f
            LEFT JOIN snowflake.trust_center.scanners s
              ON f.scanner_package_id = s.scanner_package_id
              AND f.scanner_id = s.id
            WHERE true
              AND account_name != ?
              AND s.description IS NOT NULL
              AND s.short_description IS NOT NULL
            UNION ALL
            SELECT
                ? as account_name,
                scanner_package_id,
                scanner_id,
                state,
                severity,
                end_timestamp as updated_on,
                total_at_risk_count > 0 as included,
            FROM snowflake.trust_center.findings
            WHERE scanner_type = 'Vulnerability'
        ),
        latest_org_findings AS (
          SELECT
            scanner_package_id,
            scanner_id,
            account_name,
            severity,
            updated_on,
            state,
            included,
            ROW_NUMBER() OVER (
              PARTITION BY account_name, scanner_package_id, scanner_id
              ORDER BY updated_on DESC NULLS LAST
            ) as rn
          FROM combined_findings
          WHERE account_name IS NOT NULL
          AND severity = 'CRITICAL'
        )
        SELECT
          lof.account_name as account_name,
          COUNT(1) as finding_count
        FROM latest_org_findings lof
        WHERE lof.rn = 1 and lof.included = true and UPPER(lof.state) = 'OPEN'
        GROUP BY lof.account_name
        ORDER BY finding_count DESC
        `,bindingsJSON:[r,r]},role:e,isInternal:!0,desc:"trust-center-org-top-violations",...t&&{warehouse:t},feature:h6}))({role:e,warehouse:t,currentAccountName:r}))}}async trustCenterOrgViolationsByScannerPackage({role:e,warehouse:t,currentAccountName:r}){return{result:await this.sqlQueryBackend.query((({role:e,warehouse:t,currentAccountName:r})=>({sqlQuery:{sqlText:`
